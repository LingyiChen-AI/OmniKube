# OmniKube 后端配置示例。复制为 config.yaml 后填入真实值。
# 敏感项 (database.url / auth.jwt_secret / crypto.master_key) 可用同名大写环境变量覆盖，
# 生产建议密钥走环境变量 / KMS，不写入此文件。

server:
  port: "8080"

database:
  # 也可用环境变量 DATABASE_URL 覆盖
  url: "postgres://omnikube:omnikube@localhost:5433/omnikube?sslmode=disable"

auth:
  # 至少 32 字符；也可用环境变量 JWT_SECRET 覆盖。可用: openssl rand -hex 32
  jwt_secret: "change-me-to-a-long-random-string-min-32-chars"
  jwt_expiry: "24h"

crypto:
  # base64 编码的 32 字节；也可用环境变量 MASTER_KEY 覆盖。可用: openssl rand -base64 32
  master_key: ""

admin:
  username: "admin"
